# Copy to .env for local overrides. Never commit the real .env.

# Paths
PIT_PROJECT_ROOT=.
PIT_DATA_ROOT=./data
PIT_ARTIFACT_ROOT=./artifacts
PIT_DATASET=sample
PIT_PAYSIM_CSV=./data/raw/paysim/PS_20174392719_1491204439457_log.csv
# Versioned contracts
PIT_ENTITY_DEFINITION_VERSION=entity-application-candidate-v0
PIT_FEATURE_DEFINITION_VERSION=fraud-history-v1
PIT_FEATURE_SERVICE_VERSION=fraud-scoring-v1
PIT_FLOAT_TOLERANCE=1e-6

# Local services
PIT_REDIS_URL=redis://localhost:6379/0
PIT_MLFLOW_TRACKING_URI=http://localhost:5000
PIT_API_HOST=127.0.0.1
PIT_API_PORT=8000
PIT_JUPYTER_PORT=8888
PIT_JUPYTER_TOKEN=pit-local
PIT_LOG_LEVEL=INFO
PIT_LOG_JSON=false

# Dataset access. Raw data remains gitignored.
KAGGLE_DATASET=ealaxi/paysim1
# KAGGLE_USERNAME=
# KAGGLE_KEY=
